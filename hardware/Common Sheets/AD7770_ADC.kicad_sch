			(justify left top)
		)
		(uuid "fc825f63-18a6-4558-94ca-644b5326abd3")
	)
	(text_box "Hold ~{RESET} low for at least 2 MCLK cycles (244 ns) to trigger a reset of the chip. The datasheet recommends issuing a reset after power-up."
