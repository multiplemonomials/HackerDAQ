		)
		(uuid "6551df74-c780-4ab5-8123-7f33e0e923ac")
	)
	(text_box "Using GPIO2 to provide CONVST_SAR signal to enable triggering the SAR ADC from an SPI transaction. Somehow there is no built-in way to do this??"
		(exclude_from_sim no)
		(at 248.92 115.57 0)
		(size 38.1 13.97)
