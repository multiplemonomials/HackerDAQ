	(text_box "Analog inputs.\nThese are the 8 analog input channels for the ADC. The differential voltage range is +-V_REF / 2, i.e. if V_REF is 2.5V, the differential voltage range is +-1.25V.\nAnalog inputs are not rail-to-rail: They must be at least 0.1V above AGND and 0.1V below AVDD at all times. For example, if AVDD is 3.3V and AGND is 0V, analog inputs must stay between 0.1V and 3.2V.\nThere are no restrictions on common-mode voltage as long as the above limitation is followed."
		(exclude_from_sim no)
		(at 93.98 93.98 0)
		(size 58.42 24.13)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.1588)
			)
			(justify left top)
		)
		(uuid "03266a9d-3c73-4626-8fa8-8e2afdbedd9c")
	)
