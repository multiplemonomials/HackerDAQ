		(uuid "6e3229af-3be7-4829-b8eb-907a6682164e")
	)
	(text_box "The AD7770 integrates a 2.5V voltage reference with +-0.2% (+-5mV) initial accuracy and 10ppm/degC temperature error.\n\nThe internal reference or an external reference (with optional buffering) may be selected via SPI registers.\n\nNote that use of this reference (without an active external filter) adds some additional noise and decreases the maximum SNR of the ADC from ~110dBm to ~100dBm."
		(exclude_from_sim no)
		(at 102.87 184.15 0)
		(size 48.26 27.94)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "80c477ea-bb61-4816-87f2-c1eee5d5a6ac")
	)
	(text_box "Clock input.\nNeeds a logic level 8.192MHz clock at IOVDD logic levels."
		(exclude_from_sim no)
		(at 261.62 165.1 0)
		(size 26.67 10.16)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "96ec3bf7-e633-4a1a-9c1f-45807d79206a")
	)
	(text_box "Analog supply voltage.\nMust be between 3.0V and 3.6V relative to AGND."
		(exclude_from_sim no)
		(at 168.91 22.86 0)
		(size 29.21 10.16)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "aa81fba3-21b0-43ec-8b36-7acd089aada1")
	)
	(text_box "Common mode voltage output.\nThe ADC provides a buffered output that is halfway between AVDD and AGND. This can source approximately 1mA, and is intended to supply the AIN- inputs if you wish supply a single ended input voltage."
		(exclude_from_sim no)
		(at 111.76 64.77 0)
		(size 49.53 15.24)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "b37db235-d77c-4594-81da-2ca67cbd4143")
	)
	(text_box "DRDY will make a falling edge whenever there are new conversion data to read."
		(exclude_from_sim no)
		(at 298.45 105.41 0)
		(size 38.1 8.89)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "c29543d8-b149-43a0-911c-707e1c8d1c6f")
	)
	(text_box "Analog ground.\nThe ADS7770 supports dual supply operation. To do this, you may set AGND as low as -1.8V relative to DGND, as long as the AVDD to AGND voltage is within spec. AGND cannot be a higher voltage than DGND."
		(exclude_from_sim no)
		(at 165.1 213.36 0)
		(size 33.02 25.4)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "d1f36f22-6c64-43ae-9010-73ef27de1545")
	)
	(text_box "I/O supply voltage.\nMust be between 1.8V and 3.6V relative to DGND."
		(exclude_from_sim no)
		(at 248.92 54.61 0)
		(size 29.21 10.16)
		(margins 0.9525 0.9525 0.9525 0.9525)
