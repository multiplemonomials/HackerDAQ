	(text "B2B carries the following signals:\n\n- Supply voltage from main board to card\n- Digital +5V and +3.3V rails from main board to card\n- SPI (MOSI, MISO, SCLK)\n- 3x chip selects\n- 8.192MHz clock (for AD7770 ADC)\n- Sync signal from main board to card\n- Data ready signal from card to main board\n- Reset line from main board to card"
		(exclude_from_sim no)
		(at 34.036 40.132 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "53b3b0ae-d527-4181-ad20-ff34e3524131")
	)
	(text_box "Pins 9 and 2 intentionally used for GND so that shorting them to pin 1 won't put 24V on a power rail or digital line."
		(exclude_from_sim no)
