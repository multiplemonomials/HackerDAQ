				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "78f0d3cc-c394-4072-9ad6-5f4f3573b60b")
	)
	(text_box "SWD debug connector. Not using JTAG as it's not worth the two extra pins for no additional benefit.\nResistors on SWDIO and SWCLK are per hardware design guide recommendation."
		(exclude_from_sim no)
