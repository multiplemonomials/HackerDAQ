	(text_box "Reset circuit. Can be pulled low from the pushbutton or the JTAG connector. Also pulled low at startup by the MCU during its power-on reset.\nThe diode exists to discharge the capacitor when power is turned off."
		(exclude_from_sim no)
		(at 102.87 166.37 0)
		(size 45.72 16.51)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
