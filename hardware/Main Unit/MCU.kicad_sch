				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "06c9cd07-5b03-4c11-bf16-2c88e257997f")
	)
	(text_box "Note: Decoupling per hardware design guide. Generally each group of pins gets one large capacitor, and each pin gets a smaller capacitor"
		(exclude_from_sim no)
		(at 24.13 25.4 0)
		(size 39.37 12.7)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "4c890bcd-02e0-4326-b093-4d39ed5b9c3c")
	)
	(text_box "Main CPU clock source. Yeah we could get away with using the internal oscillator to drive the CPU core, but it's not accurate enough for Ethernet so we'd still need a crystal oscillator. So why not plonk down a TCXO and enjoy +-5ppm accurate clocks for everything?"
		(exclude_from_sim no)
		(at 13.97 173.99 0)
		(size 41.91 20.32)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "78f0d3cc-c394-4072-9ad6-5f4f3573b60b")
	)
	(text_box "SWD debug connector. Not using JTAG as it's not worth the two extra pins for no additional benefit.\nResistors on SWDIO and SWCLK are per hardware design guide recommendation."
		(exclude_from_sim no)
		(at 29.21 276.86 0)
		(size 45.72 13.97)
		(margins 0.9525 0.9525 0.9525 0.9525)
